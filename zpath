# Base PATH bits you always want, even for scripts
# (Avoid heavy evals here.)
#
# ensure no duplicates when we manipulate $path (zsh array form)
typeset -U path PATH
path=(
  $HOME/.local/bin
  $HOME/bin
  $HOME/.cargo/bin
  $HOME/go/bin
  $HOME/.opencode/bin
  $ANDROID_HOME/platform-tools
  $HOMEBREW_PREFIX/bin
  $HOMEBREW_PREFIX/sbin
  $HOMEBREW_PREFIX/opt/openjdk@21/bin
  $HOMEBREW_PREFIX/opt/ruby/bin
  $HOMEBREW_PREFIX/lib/ruby/gems/3.2.0/bin
  /usr/local/bin
  /usr/bin /bin /usr/sbin /sbin
  $path
)
export PATH
