theme = Catppuccin Mocha
split-divider-color = #FFFFFF
keybind = shift+enter=text:\n
auto-update-channel = tip

# Launch tmux automatically, attaching to "main" session or creating it
command = /bin/zsh -l -c "tmux new-session -A -s main"

# Remap Cmd-T: create new tmux window instead of Ghostty tab
# \x02 = Ctrl-B (tmux prefix), t = new-window binding from tmux.conf
keybind = cmd+t=text:\x02t

# Remap Cmd+Shift+[/]: navigate tmux windows (prev/next)
# p = previous-window, n = next-window (tmux defaults)
keybind = cmd+shift+left_bracket=text:\x02p
keybind = cmd+shift+right_bracket=text:\x02n

# Remap Cmd-W: close current tmux window (prefix + &)
keybind = cmd+w=text:\x02&

# Rename current tmux window (tab) with Cmd-R (prefix + ,)
keybind = cmd+r=text:\x02,

# Rename current tmux session with Cmd+Shift+R (prefix + $)
keybind = cmd+shift+r=text:\x02$

# Split vertically (side by side) with Cmd-D (prefix + %)
keybind = cmd+d=text:\x02%

# Split horizontally (stacked) with Cmd+Shift+D (prefix + ")
keybind = cmd+shift+d=text:\x02"

# Create new tmux session with Cmd+Shift+N (prefix + C)
keybind = cmd+shift+n=text:\x02C

# Switch tmux session with Cmd+Shift+S (prefix + s, built-in tree view)
keybind = cmd+shift+s=text:\x02s
