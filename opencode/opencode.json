{
  "$schema": "https://opencode.ai/config.json",
  "theme": "catppuccin",
  "autoupdate": true,
  "plugin": [
    "opencode-anthropic-auth@latest"
  ],
  "provider": {
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    }
  },
  "permission": {
    "bash": {
      "git push": "ask",
      "git merge *": "ask"
    }
  }
}
